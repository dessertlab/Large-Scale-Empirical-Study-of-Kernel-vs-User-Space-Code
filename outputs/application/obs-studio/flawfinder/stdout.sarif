            {
              "id": "FF1067",
              "name": "free/memalign",
              "shortDescription": {
                "text": "On some systems (though not Linux-based systems) an attempt to free() results from memalign() may fail. This may, on a few systems, be exploitable. Also note that memalign() may not check that the boundary parameter is correct (CWE-676)."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/676.html",
              "relationships": [
                {
                  "target": {
                    "id": "CWE-676",
                    "toolComponent": {
