                    }
                  },
                  "kinds": [
                    "relevant"
                  ]
                }
              ]
            },
            {
              "id": "FF1023",
              "name": "buffer/MultiByteToWideChar",
              "shortDescription": {
                "text": "Requires maximum length in CHARACTERS, not bytes (CWE-120)."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/120.html",
