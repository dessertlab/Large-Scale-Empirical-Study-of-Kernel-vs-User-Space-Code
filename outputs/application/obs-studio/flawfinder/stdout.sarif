            {
              "id": "FF1048",
              "name": "random/srand",
              "shortDescription": {
                "text": "This function is not sufficiently random for security-related functions such as key and nonce creation (CWE-327)."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/327.html",
