            },
            {
              "id": "FF1026",
              "name": "buffer/realpath",
              "shortDescription": {
                "text": "This function does not protect against buffer overflows, and some implementations can overflow internally (CWE-120/CWE-785!)."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/120.html",
