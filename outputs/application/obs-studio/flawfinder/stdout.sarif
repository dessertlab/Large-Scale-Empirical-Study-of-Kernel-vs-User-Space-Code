                  ]
                }
              ]
            },
            {
              "id": "FF1060",
              "name": "misc/SetSecurityDescriptorDacl",
              "shortDescription": {
                "text": "Never create NULL ACLs; an attacker can set it to Everyone (Deny All Access), which would even forbid administrator access (CWE-732)."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/732.html",
