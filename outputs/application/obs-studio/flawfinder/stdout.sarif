            {
              "id": "FF1058",
              "name": "misc/LoadLibrary",
              "shortDescription": {
                "text": "Ensure that the full path to the library is specified, or current directory may be used (CWE-829, CWE-20)."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/829.html",
              "relationships": [
                {
                  "target": {
                    "id": "CWE-829",
