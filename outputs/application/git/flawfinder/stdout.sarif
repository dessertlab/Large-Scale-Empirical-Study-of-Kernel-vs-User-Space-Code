                    }
                  },
                  "kinds": [
                    "relevant"
                  ]
                }
              ]
            },
            {
              "id": "FF1036",
              "name": "tmpfile/tmpfile",
              "shortDescription": {
                "text": "Function tmpfile() has a security flaw on some systems (e.g., older System V systems) (CWE-377)."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/377.html",
              "relationships": [
