              "id": "FF1042",
              "name": "tmpfile/GetTempFileName",
              "shortDescription": {
                "text": "Temporary file race condition in certain cases (e.g., if run as SYSTEM in many versions of Windows) (CWE-377)."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/377.html",
