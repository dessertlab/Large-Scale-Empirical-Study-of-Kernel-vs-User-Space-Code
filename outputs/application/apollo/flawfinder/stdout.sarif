            {
              "id": "FF1039",
              "name": "tmpfile/mkstemp",
              "shortDescription": {
                "text": "Potential for temporary file vulnerability in some circumstances. Some older Unix-like systems create temp files with permission to write by all by default, so be sure to set the umask to override this. Also, some older Unix systems might fail to use O_EXCL when opening the file, so make sure that O_EXCL is used by the library (CWE-377)."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/377.html",
              "relationships": [
                {
                  "target": {
                    "id": "CWE-377",
                    "toolComponent": {
