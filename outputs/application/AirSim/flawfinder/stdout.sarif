                  ]
                }
              ]
            },
            {
              "id": "FF1047",
              "name": "integer/atoi",
              "shortDescription": {
                "text": "Unless checked, the resulting number can exceed the expected range (CWE-190)."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/190.html",
              "relationships": [
