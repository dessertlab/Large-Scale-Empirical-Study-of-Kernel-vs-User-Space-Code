                    }
                  },
                  "kinds": [
                    "incomparable"
                  ]
                }
              ]
            },
            {
              "id": "FF1027",
              "name": "buffer/getopt",
              "shortDescription": {
                "text": "Some older implementations do not protect against internal buffer overflows (CWE-120, CWE-20)."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/120.html",
