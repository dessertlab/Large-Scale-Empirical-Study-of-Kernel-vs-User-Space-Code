              "id": "FF1007",
              "name": "buffer/StrCat",
              "shortDescription": {
                "text": "Does not check for buffer overflows when concatenating to destination [MS-banned] (CWE-120)."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/120.html",
              "relationships": [
                {
                  "target": {
                    "id": "CWE-120",
                    "toolComponent": {
                      "name": "CWE",
                      "guid": "FFC64C90-42B6-44CE-8BEB-F6B7DAE649E5"
                    }
                  },
                  "kinds": [
                    "relevant"
                  ]
                }
              ]
            },
            {
              "id": "FF1071",
              "name": "buffer/equal",
              "shortDescription": {
                "text": "Function does not check the second iterator for over-read conditions (CWE-126)."
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/126.html",
              "relationships": [
                {
