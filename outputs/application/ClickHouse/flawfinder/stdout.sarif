                    }
                  },
                  "kinds": [
                    "incomparable"
                  ]
                }
              ]
            },
            {
              "id": "FF1035",
              "name": "race/readlink",
              "shortDescription": {
                "text": "This accepts filename arguments; if an attacker can move those files or change the link content, a race condition results. Also, it does not terminate with ASCII NUL. (CWE-362, CWE-20)."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/362.html",
              "relationships": [
