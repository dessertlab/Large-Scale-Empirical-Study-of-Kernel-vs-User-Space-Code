                    }
                  },
                  "kinds": [
                    "relevant"
                  ]
                }
              ]
            },
            {
              "id": "FF1001",
              "name": "buffer/strcpy",
              "shortDescription": {
                "text": "Does not check for buffer overflows when copying to destination [MS-banned] (CWE-120)."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/120.html",
