                }
              ]
            },
            {
              "id": "FF1015",
              "name": "buffer/vsprintf",
              "shortDescription": {
                "text": "Does not check for buffer overflows (CWE-120)."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/120.html",
              "relationships": [
                {
                  "target": {
                    "id": "CWE-120",
